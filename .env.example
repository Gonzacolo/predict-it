# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# After claim, “Play again” opens this URL (default in code is production deploy).
# For local dev: NEXT_PUBLIC_PLAY_AGAIN_URL=http://localhost:3000/app
# NEXT_PUBLIC_PLAY_AGAIN_URL=https://predict-it-one.vercel.app/app

# Demo HUD (optional)
# NEXT_PUBLIC_GAME_DEV_HUD=false

# --- On-chain game (Ola 2) ---
# When false, the /app game stays in local demo mode (no wallet, no RPC).
NEXT_PUBLIC_GAME_ONCHAIN_ENABLED=false

# Arc Testnet (see docs/onchain-smart-contracts-backend-prd.md)
NEXT_PUBLIC_CHAIN_ID=5042002
NEXT_PUBLIC_RPC_URL=https://rpc.testnet.arc.network

# Optional: block explorer base URL (no trailing slash); default matches Arc testnet in code
# NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://testnet.arcscan.app

# Deployed contracts (set after deploy + configure)
NEXT_PUBLIC_GAME_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Dynamic (https://app.dynamic.xyz) — required when NEXT_PUBLIC_GAME_ONCHAIN_ENABLED=true
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# Server: operator wallet (USDC transfer for /api/game/fund). Keep secret.
GAME_OPERATOR_PRIVATE_KEY=

# Server: escrow owner key for /api/game/settle (must match contract owner).
GAME_ESCROW_OWNER_PRIVATE_KEY=

# Optional: Dynamic REST API (used to verify SDK wiring; extend for server wallets).
DYNAMIC_API_KEY=

# --- Foundry only (deploy / configure scripts). Never commit real keys. ---
# Wallet that pays gas for forge broadcast (can differ from GAME_ESCROW_OWNER).
# PRIVATE_KEY=0x...
#
# DeployGameEscrow.s.sol:
# GAME_USDC_ADDRESS=0x3600000000000000000000000000000000000000
# GAME_ESCROW_OWNER=0x...   # must match GAME_ESCROW_OWNER_PRIVATE_KEY address on-chain
# GAME_HOUSE_FEE_BPS=100
#
# After deploy, set NEXT_PUBLIC_GAME_ESCROW_ADDRESS above, then ConfigureGameEscrow.s.sol (run once per clip):
# GAME_ESCROW_ADDRESS=0x...
# GAME_BANKROLL_AMOUNT=0
# GAME_DEFAULT_CLIP_ID=1
# GAME_DEFAULT_CLIP_ENABLED=true
# GAME_DEFAULT_CLIP_DIRECTION=0
# GAME_DEFAULT_CLIP_OUTCOME=0
